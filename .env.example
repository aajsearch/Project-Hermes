# Copy to .env and fill in values. Do not commit .env.

# --- Kalshi API (required for live trading and V2 pipeline) ---
KALSHI_API_KEY=your-api-key-id
KALSHI_PRIVATE_KEY=/path/to/your/private-key.pem
# Base URL only (no path). Production: api.elections.kalshi.com
KALSHI_BASE_URL=https://api.elections.kalshi.com
# Set to 0 or false to disable Kalshi WebSocket; pipeline uses REST only for market + quote (avoids WS debugging).
# KALSHI_USE_WS=0

# --- Hourly ledger email (optional, legacy) ---
# Gmail: use App Password (https://myaccount.google.com/apppasswords), not your normal password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=your-email@gmail.com
SMTP_TO=recipient@example.com

# --- Alpaca options API (required for Alpaca PCS/CCS/IC sniper process) ---
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET_KEY=your-alpaca-secret-key

# Optional: enable extra log alerts for PCS/CCS/IC.
# ALPACA_ALERTS_ENABLED=1

# Optional: enable extra selector debug logs (PCS/CCS/IC).
# ALPACA_PUT_SPREAD_DEBUG=1

# --- Coinbase Advanced Trade (CDP) — grid bot + check_balances.py ---
# Download a CDP API key JSON from https://cloud.coinbase.com/access/api (must include "name" + PEM "privateKey").
COINBASE_KEY_FILE=./cdp_api_key-trading-bot.json
# Optional: restrict diagnostics to one portfolio UUID (from Coinbase Advanced UI / API list).
# COINBASE_RETAIL_PORTFOLIO_ID=
COINBASE_GRID_CONFIG=./coinbase_grid_bot/config.yaml
# Alternative to COINBASE_KEY_FILE:
# COINBASE_API_KEY=organizations/.../apiKeys/...
# COINBASE_API_SECRET="-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----"

# --- Coinbase trading fast-path (recommended for strategy loop) ---
# If set, the strategy can fetch balances without scanning all accounts.
TRADING_PORTFOLIO_ID=
USD_ACCOUNT_UUID=
