# Copy to .env and fill in values. Do not commit .env.

# --- Kalshi API (required for live trading and V2 pipeline) ---
KALSHI_API_KEY=your-api-key-id
KALSHI_PRIVATE_KEY=/path/to/your/private-key.pem
# Base URL only (no path). Production: api.elections.kalshi.com
KALSHI_BASE_URL=https://api.elections.kalshi.com
# Set to 0 or false to disable Kalshi WebSocket; pipeline uses REST only for market + quote (avoids WS debugging).
# KALSHI_USE_WS=0

# --- Hourly ledger email (optional, legacy) ---
# Gmail: use App Password (https://myaccount.google.com/apppasswords), not your normal password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=your-email@gmail.com
SMTP_TO=recipient@example.com
